{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/approval.schema.json",
  "title": "Approval",
  "description": "Approval tracking for a task step.",
  "type": "object",
  "properties": {
    "taskId": {
      "type": "string",
      "description": "The task being approved."
    },
    "stepId": {
      "type": "string",
      "description": "The step being approved."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"],
      "description": "Approval status."
    },
    "approvedBy": {
      "type": "string",
      "description": "Identity of the approver."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the approval decision was made."
    },
    "comment": {
      "type": "string",
      "description": "Optional comment from the approver."
    }
  },
  "required": ["taskId", "stepId", "status"],
  "additionalProperties": false
}
