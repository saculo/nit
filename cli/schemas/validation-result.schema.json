{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/validation-result.schema.json",
  "title": "Validation Result",
  "description": "Outcome of a schema or policy validation check.",
  "type": "object",
  "properties": {
    "schemaValid": {
      "type": "boolean",
      "description": "Whether the artifact passed schema validation."
    },
    "policyValid": {
      "type": "boolean",
      "description": "Whether the artifact passed policy validation."
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning"] }
        },
        "required": ["path", "message"]
      },
      "description": "List of validation errors."
    },
    "action": {
      "type": "string",
      "enum": ["repair", "proceed"],
      "description": "Recommended action based on validation outcome."
    }
  },
  "required": ["schemaValid", "policyValid", "errors", "action"],
  "additionalProperties": false
}
