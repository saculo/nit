{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/adr-triggers.schema.json",
  "title": "ADR Triggers",
  "description": "Conditions that trigger automatic ADR (Architecture Decision Record) creation.",
  "type": "object",
  "properties": {
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Trigger identifier."
          },
          "condition": {
            "type": "string",
            "description": "Description of the condition that triggers ADR creation."
          },
          "template": {
            "type": "string",
            "description": "ADR template to use when triggered."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this trigger is active."
          }
        },
        "required": ["id", "condition"]
      }
    }
  },
  "required": ["triggers"],
  "additionalProperties": false
}
