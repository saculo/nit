{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/validation-config.schema.json",
  "title": "Validation Config",
  "description": "Configuration for validation policy settings.",
  "type": "object",
  "properties": {
    "strictMode": {
      "type": "boolean",
      "description": "Whether to enforce strict validation (fail on warnings)."
    },
    "schemas": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether schema validation is enabled."
        },
        "additionalSchemaDir": {
          "type": "string",
          "description": "Path to additional schema files."
        }
      },
      "additionalProperties": false
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] }
        },
        "required": ["name", "enabled"],
        "additionalProperties": false
      },
      "description": "Policy checks to run during validation."
    }
  },
  "additionalProperties": false
}
