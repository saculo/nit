{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/roles.schema.json",
  "title": "Roles",
  "description": "Registry of specialist roles.",
  "type": "object",
  "properties": {
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Role identifier."
          },
          "label": {
            "type": "string",
            "description": "Human-readable label."
          },
          "description": {
            "type": "string",
            "description": "What this role does."
          },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Capabilities this role provides."
          }
        },
        "required": ["id", "label"]
      }
    }
  },
  "required": ["roles"],
  "additionalProperties": false
}
