{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/archetype.schema.json",
  "title": "Archetype",
  "description": "Archetype definition governing a task's step sequence and routing.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique archetype identifier."
    },
    "abstract": {
      "type": "boolean",
      "description": "Whether this archetype is abstract (cannot be used directly, only extended)."
    },
    "extends": {
      "type": "string",
      "description": "Parent archetype this one extends."
    },
    "engineerRole": {
      "type": "string",
      "description": "The engineer role that replaces the $engineer placeholder in steps."
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      },
      "description": "Ordered step definitions for this archetype."
    },
    "rejectionRouting": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of step id to the step id to route to on rejection."
    },
    "overrides": {
      "type": "object",
      "properties": {
        "removeSteps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Step ids to remove from the parent."
        },
        "addSteps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/addStep"
          },
          "description": "Steps to add, each with an 'after' field indicating insertion point."
        },
        "steps": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "approval": { "type": "boolean" }
            },
            "additionalProperties": false
          },
          "description": "Step property modifications keyed by step id."
        }
      },
      "additionalProperties": false,
      "description": "Step-level overrides for child archetypes."
    }
  },
  "required": ["id"],
  "additionalProperties": false,
  "if": {
    "not": {
      "required": ["extends"]
    }
  },
  "then": {
    "required": ["id", "steps"]
  },
  "$defs": {
    "step": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "approval": { "type": "boolean" }
      },
      "required": ["id", "role"],
      "additionalProperties": false
    },
    "addStep": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "approval": { "type": "boolean" },
        "after": {
          "type": "string",
          "description": "Insert this step after the step with this id."
        }
      },
      "required": ["id", "role", "after"],
      "additionalProperties": false
    }
  }
}
