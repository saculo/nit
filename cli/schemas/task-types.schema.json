{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nit.dev/schemas/task-types.schema.json",
  "title": "Task Types",
  "description": "Registry of recognized task types.",
  "type": "object",
  "properties": {
    "types": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Task type identifier."
          },
          "label": {
            "type": "string",
            "description": "Human-readable label."
          },
          "description": {
            "type": "string",
            "description": "What this task type represents."
          },
          "defaultArchetype": {
            "type": "string",
            "description": "Default archetype for tasks of this type."
          }
        },
        "required": ["id", "label"]
      }
    }
  },
  "required": ["types"],
  "additionalProperties": false
}
